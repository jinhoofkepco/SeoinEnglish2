        },
        "sentences": [
          {
            "id": "s1",
            "text": "Long ago, a group of people called the Phoenicians ruled the Mediterranean Sea.",
            "clauses": [
              { "id": "s1_cl0", "parent": null, "depth": 0, "role": "main", "hostChunkId": null }
            ],
            "chunks": [
              { "id": "s1_c1", "text": "Long ago,", "role": "adjunct_time", "clauseId": "s1_cl0", "opensClause": null, "attachesTo": null },
              { "id": "s1_c2", "text": "a group of people", "role": "subject", "clauseId": "s1_cl0", "opensClause": null, "attachesTo": null },
              { "id": "s1_c3", "text": "called the Phoenicians", "role": "modifier", "clauseId": "s1_cl0", "opensClause": null, "attachesTo": "s1_c2" },
