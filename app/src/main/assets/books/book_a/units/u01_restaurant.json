              { "id": "s4_c3", "text": "the rarest and most desired color", "role": "complement", "clauseId": "s4_cl0", "opensClause": null, "attachesTo": null },
              { "id": "s4_c4", "text": "in ancient times.", "role": "adjunct_time", "clauseId": "s4_cl0", "opensClause": null, "attachesTo": null }
            ]
          },
          {
            "id": "s6",
            "text": "To create Tyrian purple, people needed the slime of the Murex snail.",
            "clauses": [
              { "id": "s6_cl0", "parent": null, "depth": 0, "role": "main", "hostChunkId": null }
            ],
            "chunks": [
              { "id": "s6_c1", "text": "To create Tyrian purple,", "role": "adjunct_purpose", "clauseId": "s6_cl0", "opensClause": null, "attachesTo": null },
